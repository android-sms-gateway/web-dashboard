# Goose
GOOSE_DRIVER=mysql
GOOSE_DBSTRING='example:example@tcp(127.0.0.1:3306)/example?charset=utf8mb4&parseTime=True&loc=UTC'
GOOSE_MIGRATION_DIR=internal/db/migrations

# Actions
AWS_REGION=
AWS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_ENDPOINT=

# Web Dashboard Configuration
# Connects to an SMS Gateway server via its 3rd Party API.

# HTTP server
HTTP__LISTEN=127.0.0.1:3001

# SMS Gateway API to connect to
GATEWAY__URL=https://api.sms-gate.app/3rdparty/v1

# Public-facing URL for this dashboard (used for webhook registration)
GATEWAY__WEBHOOK_URL=http://localhost:3001/api/webhooks/callback
